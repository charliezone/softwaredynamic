{
  "name": "softwaredynamic",
  "version": "1.0.0",
  "description": "Software Dynamic LLC - Agency Website",
  "scripts": {
    "build:css": "npx @tailwindcss/cli --input ./src/input.css --output ./dist/output.css --content './get-landing/**/*.html' --content './src/**/*.html' --minify",
    "dev:css": "npx @tailwindcss/cli --input ./src/input.css --output ./dist/output.css --content './get-landing/**/*.html' --content './src/**/*.html' --watch",
    "dev": "npx concurrently \"npm run dev:css\" \"npx live-server --port=3000 --no-browser\"",
    "build": "npm run build:css"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.0.0",
    "tailwindcss": "^4.0.0",
    "concurrently": "^9.0.0",
    "live-server": "^1.2.2"
  }
}
